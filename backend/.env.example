PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ai-expense-tracker
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# When true, uses sample receipt data if Gemini returns 429 (quota)
ENABLE_AI_DEMO_FALLBACK=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CLIENT_URL=http://localhost:5173
MAX_FILE_MB=8
